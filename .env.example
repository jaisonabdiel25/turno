# Conexión a PostgreSQL
# Si usas el docker-compose incluido, el puerto es 5440 y usuario/clave/bd = turno
DATABASE_URL="postgresql://turno:turno@localhost:5440/turno?schema=public"

# Secreto para Auth.js (genera uno con: npx auth secret  o  openssl rand -base64 32)
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# URL base de la app (para Auth.js en producción)
# AUTH_URL="http://localhost:3000"
